rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Collection-group queries (e.g. collectionGroup('pets')) require a path
    // pattern that matches documents in any subcollection named "pets".
    match /{path=**}/pets/{petId} {
      allow read: if request.auth != null;
    }

    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /pets/{petId} {
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /meetups/{meetupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    match /petBuddies/{buddyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerIds is list
        && request.auth.uid in request.resource.data.ownerIds;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.ownerIds;
    }

    // Mutual block: neither owner can send pet buddy requests until unmuted.
    function petBuddyOwnerMutePairPath(fromUid, toUid) {
      let a = fromUid < toUid ? fromUid : toUid;
      let b = fromUid < toUid ? toUid : fromUid;
      return /databases/$(database)/documents/petBuddyOwnerMutes/$(a + '_' + b);
    }

    match /petBuddyOwnerMutes/{pairId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] is string
        && request.resource.data.participants[1] is string
        && request.resource.data.participants[0]
            < request.resource.data.participants[1]
        && pairId == request.resource.data.participants[0] + '_'
            + request.resource.data.participants[1]
        && request.auth.uid in request.resource.data.participants;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }

    // Pet journal entries; public ones are readable by all signed-in users.
    match /passportEntries/{entryId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || resource.data.isPublic == true);

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.petId is string
        && request.resource.data.meetupId is string;

      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /partyInvites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.hostId == request.auth.uid
            || resource.data.guestId == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if request.auth != null
        && resource.data.guestId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined'];

      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    // Pet → pet link: sender creates pending doc; recipient accepts or declines.
    match /petBuddyRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromOwnerId == request.auth.uid
            || resource.data.toOwnerId == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.fromOwnerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.fromPetId is string
        && request.resource.data.toPetId is string
        && request.resource.data.fromOwnerId is string
        && request.resource.data.toOwnerId is string
        && !exists(petBuddyOwnerMutePairPath(
            request.resource.data.fromOwnerId,
            request.resource.data.toOwnerId));

      allow update: if request.auth != null
        && resource.data.toOwnerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.fromPetId == resource.data.fromPetId
        && request.resource.data.fromOwnerId == resource.data.fromOwnerId
        && request.resource.data.toPetId == resource.data.toPetId
        && request.resource.data.toOwnerId == resource.data.toOwnerId;

      // Either parent may delete a pending request (withdraw or clear on block).
      allow delete: if request.auth != null
        && resource.data.status == 'pending'
        && (resource.data.fromOwnerId == request.auth.uid
            || resource.data.toOwnerId == request.auth.uid);
    }

    function userProfileData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function userNeighborhoodKey() {
      return userProfileData().get('neighborhoodKey', '');
    }

    function isContentModerator() {
      return userProfileData().get('isModerator', false) == true;
    }

    match /neighborhoodNewsPosts/{postId} {
      allow read: if request.auth != null
        && userNeighborhoodKey() != ''
        && resource.data.areaKey == userNeighborhoodKey()
        && resource.data.get('hidden', false) == false;

      allow create: if request.auth != null
        && userNeighborhoodKey() != ''
        && request.resource.data.areaKey == userNeighborhoodKey()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.get('title', '').size() <= 140
        && request.resource.data.hidden == false
        && request.resource.data.authorDisplayName is string;

      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isContentModerator());

      allow update: if isContentModerator();

      match /comments/{commentId} {
        function parentNewsPost() {
          return get(/databases/$(database)/documents/neighborhoodNewsPosts/$(postId)).data;
        }

        allow read: if request.auth != null
          && userNeighborhoodKey() != ''
          && parentNewsPost().areaKey == userNeighborhoodKey()
          && parentNewsPost().get('hidden', false) == false;

        allow create: if request.auth != null
          && userNeighborhoodKey() != ''
          && parentNewsPost().areaKey == userNeighborhoodKey()
          && parentNewsPost().get('hidden', false) == false
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 1000
          && request.resource.data.authorDisplayName is string;

        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid || isContentModerator());
      }
    }

    match /neighborhoodNewsReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.postId is string
        && request.resource.data.areaKey == userNeighborhoodKey()
        && userNeighborhoodKey() != ''
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500;

      allow read: if request.auth != null
        && (isContentModerator() || resource.data.reporterId == request.auth.uid);

      allow update: if isContentModerator()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['dismissed', 'action_taken'];
    }
  }
}
