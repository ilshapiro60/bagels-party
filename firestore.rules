rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Collection-group queries (e.g. collectionGroup('pets')) require a path
    // pattern that matches documents in any subcollection named "pets".
    match /{path=**}/pets/{petId} {
      allow read: if request.auth != null;
    }

    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        // Full update of own profile
        request.auth.uid == userId
        ||
        // Allow removing self from another user's friendUids (mutual unfriend / block)
        (
          resource.data.get('friendUids', []).hasAll([request.auth.uid])
          && !request.resource.data.get('friendUids', []).hasAll([request.auth.uid])
        )
        ||
        // Allow adding self to another user's friendUids (pet buddy accepted)
        (
          !resource.data.get('friendUids', []).hasAll([request.auth.uid])
          && request.resource.data.get('friendUids', []).hasAll([request.auth.uid])
        )
      );

      match /pets/{petId} {
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /meetups/{meetupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    match /petBuddies/{buddyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerIds is list
        && request.auth.uid in request.resource.data.ownerIds;
      // resource == null means the doc doesn't exist; batch deletes on non-existent docs are no-ops.
      allow delete: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.ownerIds);
    }

    // Mutual block: neither owner can send pet buddy requests until unmuted.
    function petBuddyOwnerMutePairPath(fromUid, toUid) {
      let a = fromUid < toUid ? fromUid : toUid;
      let b = fromUid < toUid ? toUid : fromUid;
      return /databases/$(database)/documents/petBuddyOwnerMutes/$(a + '_' + b);
    }

    // Two-user `participants` list (DM / conversation create); [0] < [1] not guaranteed.
    function dmOtherFromParticipantsList(participants, me) {
      return participants[0] == me ? participants[1] : participants[0];
    }

    match /petBuddyOwnerMutes/{pairId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] is string
        && request.resource.data.participants[1] is string
        && request.resource.data.participants[0]
            < request.resource.data.participants[1]
        && pairId == request.resource.data.participants[0] + '_'
            + request.resource.data.participants[1]
        && request.auth.uid in request.resource.data.participants;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }

    // Pet journal entries; public ones are readable by all signed-in users.
    match /passportEntries/{entryId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || resource.data.isPublic == true);

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.petId is string
        && request.resource.data.meetupId is string;

      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/passportEntries/$(entryId)).data.isPublic == true;

        allow create: if request.auth != null
          && get(/databases/$(database)/documents/passportEntries/$(entryId)).data.isPublic == true
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 500;

        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      }
    }

    match /partyInvites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.hostId == request.auth.uid
            || resource.data.guestId == request.auth.uid);

      // Host sends invite (private meetup) OR guest self-RSVPs (public meetup).
      allow create: if request.auth != null
        && (
          // Host creates a pending invite for a guest.
          (request.resource.data.hostId == request.auth.uid
           && request.resource.data.status == 'pending')
          ||
          // Self-RSVP: guest creates their own accepted invite on a public meetup.
          (request.resource.data.guestId == request.auth.uid
           && request.resource.data.status == 'accepted'
           && request.resource.data.selfRsvp == true
           && exists(/databases/$(database)/documents/meetups/$(request.resource.data.meetupId))
           && get(/databases/$(database)/documents/meetups/$(request.resource.data.meetupId)).data.isPublic == true)
        );

      allow update: if request.auth != null
        && resource.data.guestId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined'];

      // Host can remove any invite; guest can cancel their own self-RSVP.
      allow delete: if request.auth != null
        && (resource.data.hostId == request.auth.uid
            || resource.data.guestId == request.auth.uid);
    }

    // Pet → pet link: sender creates pending doc; recipient accepts or declines.
    match /petBuddyRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromOwnerId == request.auth.uid
            || resource.data.toOwnerId == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.fromOwnerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.fromPetId is string
        && request.resource.data.toPetId is string
        && request.resource.data.fromOwnerId is string
        && request.resource.data.toOwnerId is string
        && !exists(petBuddyOwnerMutePairPath(
            request.resource.data.fromOwnerId,
            request.resource.data.toOwnerId));

      allow update: if request.auth != null
        && resource.data.toOwnerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.fromPetId == resource.data.fromPetId
        && request.resource.data.fromOwnerId == resource.data.fromOwnerId
        && request.resource.data.toPetId == resource.data.toPetId
        && request.resource.data.toOwnerId == resource.data.toOwnerId;

      // Either parent may delete a pending request (withdraw or clear on block).
      allow delete: if request.auth != null
        && resource.data.status == 'pending'
        && (resource.data.fromOwnerId == request.auth.uid
            || resource.data.toOwnerId == request.auth.uid);
    }

    function userProfileData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function userNeighborhoodKey() {
      return userProfileData().get('neighborhoodKey', '');
    }

    function isContentModerator() {
      return userProfileData().get('isModerator', false) == true;
    }

    match /neighborhoodNewsPosts/{postId} {
      function newsPostPhotoUrls() {
        return request.resource.data.get('photoUrls', []);
      }

      function newsPostVideoUrls() {
        return request.resource.data.get('videoUrls', []);
      }

      function newsPostHasMedia() {
        let p = newsPostPhotoUrls();
        let v = newsPostVideoUrls();
        return (p is list && p.size() > 0) || (v is list && v.size() > 0);
      }

      function newsPostMediaBounds() {
        let p = newsPostPhotoUrls();
        let v = newsPostVideoUrls();
        return (p is list && p.size() <= 5) && (v is list && v.size() <= 3);
      }

      allow read: if request.auth != null
        && userNeighborhoodKey() != ''
        && resource.data.areaKey == userNeighborhoodKey()
        && resource.data.get('hidden', false) == false;

      allow create: if request.auth != null
        && userNeighborhoodKey() != ''
        && request.resource.data.areaKey == userNeighborhoodKey()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 2000
        && newsPostMediaBounds()
        && (request.resource.data.body.size() > 0 || newsPostHasMedia())
        && request.resource.data.get('title', '').size() <= 140
        && request.resource.data.hidden == false
        && request.resource.data.authorDisplayName is string;

      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isContentModerator());

      allow update: if isContentModerator();

      match /comments/{commentId} {
        function parentNewsPost() {
          return get(/databases/$(database)/documents/neighborhoodNewsPosts/$(postId)).data;
        }

        allow read: if request.auth != null
          && userNeighborhoodKey() != ''
          && parentNewsPost().areaKey == userNeighborhoodKey()
          && parentNewsPost().get('hidden', false) == false;

        allow create: if request.auth != null
          && userNeighborhoodKey() != ''
          && parentNewsPost().areaKey == userNeighborhoodKey()
          && parentNewsPost().get('hidden', false) == false
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 1000
          && request.resource.data.authorDisplayName is string;

        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid || isContentModerator());
      }
    }

    // Party stories: any signed-in user can read; only the author can create or delete.
    match /partyStories/{storyId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // Direct messaging: only participants can read/write their conversation.
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // 2–20 participants; 1:1 DMs must not be under a pet-buddy owner mute.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 20
        && (
          request.resource.data.participants.size() != 2
          || !exists(petBuddyOwnerMutePairPath(
              request.auth.uid,
              dmOtherFromParticipantsList(
                  request.resource.data.participants,
                  request.auth.uid)))
        );

      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      function conversationExists() {
        return exists(/databases/$(database)/documents/conversations/$(conversationId));
      }

      function conversationParticipantUids() {
        return conversationExists()
          ? get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          : [];
      }

      // Mute rule only applies to 1:1 threads; group messages are not blocked by pair mutes.
      function messageSendMuteAllowed() {
        let p = conversationParticipantUids();
        let other = p[0] == request.auth.uid ? p[1] : p[0];
        return p.size() != 2 || !exists(petBuddyOwnerMutePairPath(request.auth.uid, other));
      }

      function messageMediaUrls() {
        return request.resource.data.get('mediaUrls', []);
      }

      function messageHasMedia() {
        let m = messageMediaUrls();
        return request.resource.data.keys().hasAny(['mediaUrls'])
          && m is list
          && m.size() > 0;
      }

      function messageMediaUrlsValid() {
        let m = messageMediaUrls();
        return !request.resource.data.keys().hasAny(['mediaUrls'])
          || (m is list && m.size() <= 6);
      }

      match /messages/{messageId} {
        allow read: if request.auth != null
          && conversationExists()
          && request.auth.uid in conversationParticipantUids();

        // Text and/or up to 6 media URLs; empty body allowed if media present.
        // [mediaUrls] may be absent (legacy), [], or a list of strings.
        allow create: if request.auth != null
          && conversationExists()
          && request.resource.data.fromUid == request.auth.uid
          && request.auth.uid in conversationParticipantUids()
          && request.resource.data.body is string
          && request.resource.data.body.size() <= 2000
          && messageMediaUrlsValid()
          && (request.resource.data.body.size() > 0 || messageHasMedia())
          && messageSendMuteAllowed();

        allow delete: if request.auth != null
          && conversationExists()
          && request.auth.uid in conversationParticipantUids();
      }
    }

    // Shared party album: any signed-in user can view; uploader creates/deletes.
    match /partyAlbumPhotos/{itemId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uploaderId == request.auth.uid
        && request.resource.data.meetupId is string
        && request.resource.data.mediaUrl is string;

      allow delete: if request.auth != null
        && resource.data.uploaderId == request.auth.uid;
    }

    match /neighborhoodNewsReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.postId is string
        && request.resource.data.areaKey == userNeighborhoodKey()
        && userNeighborhoodKey() != ''
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500;

      allow read: if request.auth != null
        && (isContentModerator() || resource.data.reporterId == request.auth.uid);

      allow update: if isContentModerator()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['dismissed', 'action_taken'];
    }

    // Safety reports: chat, profile, or post context.
    match /chatSafetyReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500;

      allow read: if request.auth != null
        && (isContentModerator() || resource.data.reporterId == request.auth.uid);

      allow update: if isContentModerator()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['dismissed', 'action_taken'];
    }

    match /reactions/{reactionId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.targetId is string
        && request.resource.data.reactionId is string;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Email OTP for sign-in — written only by Cloud Functions (Admin SDK).
    match /emailSignInCodes/{docId} {
      allow read, write: if false;
    }
  }
}
